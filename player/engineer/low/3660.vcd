// Choreo version 1
actor "Engineer"
{
  channel "audio"
  {
    event speak "engineer_dominationspy13"
    {
      time 0.000000 3.013605
      param "engineer_dominationspy13"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
    event expression "happySmall"
    {
      time 0.000000 3.312500
      param "player\engineer\emotion\emotion"
      param2 "happySmall"
      event_ramp
      {
        0.1000 0.6235
        3.1818 0.5569
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
