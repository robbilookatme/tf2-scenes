    {
      time 0.000000 1.737432
      param "player\soldier\emotion\emotion"
      param2 "madUpper"
      event_ramp
      {
        0.2500 0.8039
        1.3405 0.8039
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
