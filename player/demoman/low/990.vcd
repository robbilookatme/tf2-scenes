      event_ramp
      {
        0.2727 0.9882
        1.3606 0.9961
        1.5727 0.8000
        2.3939 0.6471
      }
    }
    event expression "defaultFace"
    {
      time -0.010417 1.989583
      param "player\demo\emotion\emotion"
      param2 "defaultFace"
      event_ramp
      {
        0.0000 1.0000
        1.5636 1.0000
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
