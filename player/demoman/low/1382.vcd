// Choreo version 1
actor "demoman"
{
  channel "audio"
  {
    event speak "Demoman.LaughShort04"
    {
      time 0.010417 0.495133
      param "Demoman.LaughShort04"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
    event expression "happy"
    {
      time 0.010417 1.010417
      param "player\demo\emotion\emotion"
      param2 "happy"
    }
    event expression "openJaw"
    {
      time 0.010417 0.989583
      param "player\demo\emotion\emotion"
      param2 "openJaw"
      event_ramp
      {
        0.0364 0.8000
        0.3727 0.8118
        0.4848 0.3294
        0.9606 0.2196
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
