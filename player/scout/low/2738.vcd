// Choreo version 1
event stoppoint "end"
{
  time 0.171875 -1.000000
  param "noaction"
}
actor "scout"
{
  channel "audio"
  {
    event speak "Scout.BeingShotInvincible12"
    {
      time 0.000000 0.169342
      param "Scout.BeingShotInvincible12"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
  }
  channel "exp"
  {
    event expression "s"
    {
      time -0.045434 1.062161
      param "player\scout\phonemes\phonemes"
      param2 "s"
      event_ramp
      {
        0.0818 0.7255
        1.0061 0.7216
      }
    }
    event expression "happyBigUpper"
    {
      time -0.036995 1.060051
      param "player\scout\emotion\emotion"
      param2 "happyBigUpper"
      event_ramp
      {
        0.0939 0.8667
        0.9939 0.8667
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
