      event_ramp
      {
        0.2909 0.5216
        1.8152 0.6627
        2.8202 0.6549
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
