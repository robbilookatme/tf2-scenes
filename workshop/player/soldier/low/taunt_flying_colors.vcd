        {
          0.0220 0.4863 curve_catmullrom_normalize_x_to_curve_catmullrom_normalize_x
          0.1463 0.3373 curve_catmullrom_normalize_x_to_curve_catmullrom_normalize_x
          0.2400 0.4588 curve_catmullrom_normalize_x_to_curve_catmullrom_normalize_x
