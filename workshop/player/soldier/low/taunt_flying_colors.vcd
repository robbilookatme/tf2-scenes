      {
        "CloseLid" combo
        {
          0.0460 0.5882 curve_catmullrom_normalize_x_to_curve_catmullrom_normalize_x
          0.1443 1.0000 curve_catmullrom_normalize_x_to_curve_catmullrom_normalize_x
          0.2400 0.5686 curve_catmullrom_normalize_x_to_curve_catmullrom_normalize_x
        }
        {
          0.1203 0.4980 curve_catmullrom_normalize_x_to_curve_catmullrom_normalize_x
        }
