  channel "sound"
  {
    event speak "Selection.MedicHeelClick"
    {
      time 1.686667 2.138141
      param "Selection.MedicHeelClick"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
    event speak "Selection.MedicHeelClick"
    {
