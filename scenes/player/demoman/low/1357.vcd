      time 0.000000 2.142041
      param "Demoman.AutoDejectedTie04"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
    event expression "madUpper"
    {
      time 0.000000 2.270833
      param "player\demo\emotion\emotion"
      param2 "madUpper"
    }
    event expression "mad"
    {
      time 2.010417 3.458333
      param "player\demo\emotion\emotion"
      param2 "mad"
      event_ramp
