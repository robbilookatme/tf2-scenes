// Choreo version 1
actor "demoman"
{
  channel "audio"
  {
    event speak "Demoman.LaughShort01"
    {
      time 0.000000 1.340952
      param "Demoman.LaughShort01"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
    event expression "drunkHappy"
    {
      time 0.000000 2.343750
      param "player\demo\emotion\emotion"
      param2 "drunkHappy"
    }
    event expression "openJaw"
    {
      time 0.000000 1.468750
      param "player\demo\emotion\emotion"
      param2 "openJaw"
      event_ramp
      {
        0.0970 0.6784
        0.2121 0.5412
        0.3818 0.8549
        1.1788 0.8824
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
