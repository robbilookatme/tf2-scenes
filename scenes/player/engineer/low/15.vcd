  {
    event speak "Engineer.AutoBuildingTeleporter02"
    {
      time 0.000000 1.201633
      param "Engineer.AutoBuildingTeleporter02"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
  }
  channel "emotion"
  {
    event expression "happySmallUpper"
    {
      time 0.020833 2.072917
      param "player\engineer\emotion\emotion"
      param2 "happySmallUpper"
      event_ramp
      {
        0.1818 0.9804
        1.5633 0.9882
      }
    }
    event expression "happySmall"
    {
      time 1.083333 4.125000
      param "player\engineer\emotion\emotion"
      param2 "happySmall"
      event_ramp
      {
        0.3030 0.9882
        1.4767 0.9882
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
