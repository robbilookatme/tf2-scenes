// Choreo version 1
actor "Engineer"
{
  channel "audio"
  {
    event speak "Engineer.PainSharp02"
    {
      time 0.000000 0.535510
      param "Engineer.PainSharp02"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
    event expression "defaultFace"
    {
      time 0.000000 1.000000
      param "player\engineer\emotion\emotion"
      param2 "defaultFace"
    }
    event expression "mad"
    {
      time 0.000000 1.000000
      param "player\engineer\emotion\emotion"
      param2 "mad"
      event_ramp
      {
        0.0091 0.0078
        0.0788 0.9490
        0.2667 0.2784
        0.3636 0.8706
        0.9030 0.9608
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
