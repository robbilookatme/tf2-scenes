// Choreo version 1
event stoppoint "end"
{
  time 1.875000 -1.000000
  param "noaction"
}
actor "scout"
{
  channel "audio"
  {
    event speak "Scout.Domination14"
    {
      time 0.000000 1.874671
      param "Scout.Domination14"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
  }
  channel "exp"
  {
    event expression "happySmall"
    {
      time -0.218750 1.104167
      param "player\scout\emotion\emotion"
      param2 "happySmall"
      event_ramp
      {
        0.1152 0.7882
        1.1636 0.7804
      }
    }
    event expression "mad"
    {
      time 0.906250 5.302083
      param "player\scout\emotion\emotion"
      param2 "mad"
      event_ramp
      {
        0.1182 0.5098
        4.2212 0.4627
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
