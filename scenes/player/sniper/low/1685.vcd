// Choreo version 1
actor "sniper"
{
  channel "audio"
  {
    event speak "Sniper.NeedTeleporter01"
    {
      time 0.000000 1.335147
      param "Sniper.NeedTeleporter01"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
  }
  channel "emotion"
  {
    event expression "specialAction01Upper"
    {
      time 0.000000 5.000000
      param "player\sniper\emotion\emotion"
      param2 "specialAction01Upper"
      event_ramp
      {
        0.0727 0.8510
        4.8636 0.8353
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
