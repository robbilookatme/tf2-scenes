// Choreo version 1
actor "soldier"
{
  channel "audio"
  {
    event speak "Soldier.AutoCappedControlPoint02"
    {
      time 0.000000 2.838639
      param "Soldier.AutoCappedControlPoint02"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
  }
  channel "emotion"
  {
    event expression "mad"
    {
      time 2.588639 6.088639
      param "player\soldier\emotion\emotion"
      param2 "mad"
      event_ramp
      {
        0.5000 1.0000
        2.7500 1.0000
      }
    }
    event expression "madUpper"
    {
      time 0.000000 3.088639
      param "player\soldier\emotion\emotion"
      param2 "madUpper"
      event_ramp
      {
        0.2500 1.0000
        2.5886 1.0000
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
