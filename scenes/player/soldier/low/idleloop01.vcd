// Choreo version 1
actor "soldier"
{
  channel "audio"
  {
  }
  channel "emotion"
  {
    event expression "defaultFace"
    {
      time 0.000000 15.000000
      param "player\soldier\emotion\emotion"
      param2 "defaultFace"
      event_ramp
      {
        0.2530 0.7333
        14.7714 0.7333
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
