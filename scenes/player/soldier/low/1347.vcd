// Choreo version 1
actor "soldier"
{
  channel "audio"
  {
    event speak "Soldier.LaughHappy03"
    {
      time 0.000000 2.101406
      param "Soldier.LaughHappy03"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
  }
  channel "emotion"
  {
    event expression "happySmall"
    {
      time 1.851406 5.351406
      param "player\soldier\emotion\emotion"
      param2 "happySmall"
      event_ramp
      {
        0.5000 1.0000
        2.7500 1.0000
      }
    }
    event expression "happySmallUpper"
    {
      time 0.000000 2.351406
      param "player\soldier\emotion\emotion"
      param2 "happySmallUpper"
      event_ramp
      {
        0.2500 1.0000
        1.8514 1.0000
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
