// Choreo version 1
actor "Pyro"
{
  channel "body"
  {
    event sequence "taunt_lollichop"
    {
      time 0.000000 3.000000
      param "taunt_lollichop"
      fixedlength
    }
    event speak "Pyro.Lollichop"
    {
      time 0.500000 2.500000
      param "Pyro.Lollichop"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
