// Choreo version 1
actor "spy"
{
  channel "audio"
  {
    event expression "defaultFace"
    {
      time 0.000000 15.000000
      param "player\spy\emotion\emotion"
      param2 "defaultFace"
      event_ramp
      {
        0.3061 1.0000
        14.4731 1.0000
      }
    }
  }
}
scalesettings
{
  "CChoreoView" "100"
  "SceneRampTool" "100"
  "ExpressionTool" "100"
  "GestureTool" "100"
  "RampTool" "100"
}
fps 60
snap off
